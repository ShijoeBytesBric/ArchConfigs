#!/bin/bash

menu() {
    local prompt="$1"
    local options="$2"
    printf "%b" "$options" | launch-walker --dmenu \
    --width 295 \
    --minheight 1 \
    --maxheight 630 \ 
    -p "" \
    2>/dev/null
}

choice=$(menu "power" "箚뮧  Suspend\n箚쨦  Hibernate\n箚뛽  Logout\n箚쐣  Restart\n箚맓  Shutdown\n箚뙻  Lock")

case "$choice" in
    *Suspend)   systemctl suspend ;;
    *Hibernate) systemctl hibernate ;;
    *Logout)    system-logout ;;
    *Restart)   systemctl reboot ;;
    *Shutdown)  systemctl poweroff ;;
    *Lock)      loginctl lock-session ;;
esac
